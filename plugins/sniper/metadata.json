    "requires_consent": true,
    "consent_message": "Sniper models exploit flows. Use only with explicit authorization.",
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "capabilities": [
    "network",
    "intrusive",
    "exploit"
  ],
  "dependencies": {
    "binaries": [
      "python3"
    ],
    "python_packages": [],
    "system_packages": []
