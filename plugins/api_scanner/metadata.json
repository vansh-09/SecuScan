{
  "id": "api_scanner",
  "name": "API Scanner",
  "version": "1.0.0",
  "description": "Check for specific API vulnerabilities (REST and GraphQL).",
  "long_description": "Check for specific API vulnerabilities (REST and GraphQL).",
  "category": "vulnerability",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "🛠️",
  "implementation_status": "native",
  "supports_authenticated_crawling": true,
  "supports_session_reuse": true,
  "engine": {
    "type": "cli",
    "binary": "nuclei"
  },
  "command_template": [
    "nuclei",
    "-u",
    "{target}",
    "-silent"
  ],
  "fields": [
    {
      "id": "target",
      "label": "API Base URL",
      "type": "string",
      "required": true,
      "placeholder": "https://api.secuscan.in",
      "validation": {
        "pattern": "^https?://",
        "message": "Must be a valid HTTP(S) URL"
      }
    }
  ],
  "presets": {
    "default": {}
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "intrusive",
    "requires_consent": true,
    "consent_message": "API vulnerability scanning is active and requires authorization.",
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "capabilities": [
    "network",
    "intrusive",
    "credentials"
  ],
  "dependencies": {
    "binaries": [
      "nuclei"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "90ba2af201a01543cc1064b4d489cfe2c4a5e94e9d7fb0750e18779ffb280a99"
}
